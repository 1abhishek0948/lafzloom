{% extends 'base.jinja' %}

{% block title %}{{ t('Manage Shayaris') }} | Lafzverse{% endblock %}

{% block content %}
<section>
  <p class="tag">{{ t('Moderation') }}</p>
  <h1 class="text-3xl font-display">{{ t('Manage Shayaris') }}</h1>
  <div class="mt-6 space-y-4">
    {% for shayari in shayaris %}
      <div class="card">
        <div class="flex items-start justify-between">
          <div>
            <h2 class="text-xl font-display">{{ shayari.title }}</h2>
            <p class="text-sm text-slate-400">{{ shayari.category.name }} · @{{ shayari.author.username }}</p>
          </div>
          <div class="flex flex-col items-end gap-2">
            <span class="lang-pill">{{ shayari.get_language_display() }}</span>
            {% if shayari.approved %}
              <span class="chip">{{ t('Live') }}</span>
            {% else %}
              <span class="chip">{{ t('Hidden') }}</span>
            {% endif %}
          </div>
        </div>
        <p class="mt-3 whitespace-pre-line">{{ shayari.text|truncate(240) }}</p>
        <div class="mt-4 flex flex-wrap gap-3">
          {% if shayari.approved %}
            <form method="post" action="{{ url('moderation:unpublish', pk=shayari.pk) }}">
              {{ csrf_input }}
              <button class="btn-ghost" type="submit">{{ t('Hide') }}</button>
            </form>
          {% else %}
            <form method="post" action="{{ url('moderation:approve', pk=shayari.pk) }}">
              {{ csrf_input }}
              <button class="btn-primary" type="submit">{{ t('Publish') }}</button>
            </form>
          {% endif %}
          <a class="btn-ghost" href="{{ url('moderation:edit', pk=shayari.pk) }}">{{ t('Edit') }}</a>
          <form method="post" action="{{ url('moderation:reject', pk=shayari.pk) }}" onsubmit="return confirm('{{ t('Delete this shayari?') }}');">
            {{ csrf_input }}
            <button class="btn-danger" type="submit">{{ t('Delete') }}</button>
          </form>
        </div>
      </div>
    {% else %}
      <p class="text-slate-400">{{ t('No shayaris yet.') }}</p>
    {% endfor %}
  </div>
</section>
{% endblock %}
