{% extends 'base.jinja' %}

{% block title %}{{ t('Edit') }} | Lafzloom{% endblock %}

{% block content %}
<section class="max-w-2xl">
  <p class="tag">{{ t('Edit') }}</p>
  <h1 class="text-3xl font-display">{{ t('Update your verse.') }}</h1>
  <form method="post" class="mt-6 space-y-4 card">
    {{ csrf_input }}
    {% if form.errors %}
      <div class="text-sm text-rose-200">{{ form.errors }}</div>
    {% endif %}
    <div>
      <label class="label">{{ t('Title') }}</label>
      {{ form.title }}
    </div>
    <div>
      <label class="label">{{ t('Category') }}</label>
      {{ form.category }}
    </div>
    <div>
      <label class="label">{{ t('Language') }}</label>
      {{ form.language }}
    </div>
    <div>
      <label class="label">{{ t('Your Verse') }}</label>
      {{ form.text }}
    </div>
    <div class="flex flex-wrap gap-3">
      <button class="btn-primary" type="submit">{{ t('Save Changes') }}</button>
      <a class="btn-ghost" href="{{ url('shayari:detail', pk=shayari.pk) }}">{{ t('Cancel') }}</a>
    </div>
  </form>
</section>
{% endblock %}
