{% extends 'base.jinja' %}

{% block title %}Profile | Lafzverse{% endblock %}

{% block content %}
<section>
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
      <p class="tag">{{ t('Profile') }}</p>
      <h1 class="text-3xl font-display">@{{ request.user.username }}</h1>
    </div>
    <form method="post" action="{{ url('accounts:logout') }}">
      {{ csrf_input }}
      <button class="btn-ghost" type="submit">{{ t('Logout') }}</button>
    </form>
  </div>

  <div class="mt-8 grid md:grid-cols-2 gap-6">
    <div class="card" id="uploads">
      <h2 class="section-title">{{ t('Your Shayaris') }}</h2>
      <div class="mt-4 space-y-4">
        {% for shayari in my_shayaris %}
          <div>
            <a class="text-lg font-display hover:underline" href="{{ url('shayari:detail', pk=shayari.pk) }}">{{ shayari.title }}</a>
            <p class="text-xs text-slate-400">{{ shayari.created_at|date('M d, Y') }}</p>
            <div class="mt-2 flex flex-wrap gap-3 text-xs">
              <a class="underline text-slate-300 hover:text-white" href="{{ url('shayari:edit', pk=shayari.pk) }}">{{ t('Edit') }}</a>
              <form method="post" action="{{ url('shayari:delete', pk=shayari.pk) }}" onsubmit="return confirm('{{ t('Delete this shayari?') }}');">
                {{ csrf_input }}
                <input type="hidden" name="next" value="{{ url('accounts:profile') }}">
                <button class="underline text-rose-200 hover:text-rose-100" type="submit">{{ t('Delete') }}</button>
              </form>
            </div>
          </div>
        {% else %}
          <p class="text-slate-400">{{ t('No submissions yet.') }}</p>
        {% endfor %}
      </div>
    </div>
    <div class="card" id="saved">
      <h2 class="section-title">{{ t('Saved Shayaris') }}</h2>
      <div class="mt-4 space-y-4">
        {% for shayari in saved_shayaris %}
          <div>
            <a class="text-lg font-display hover:underline" href="{{ url('shayari:detail', pk=shayari.pk) }}">{{ shayari.title }}</a>
            <p class="text-xs text-slate-400">{{ t('by') }} @{{ shayari.author.username }}</p>
          </div>
        {% else %}
          <p class="text-slate-400">{{ t('No saved shayaris yet.') }}</p>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="mt-6 card" id="liked">
    <h2 class="section-title">{{ t('Liked Shayaris') }}</h2>
    <div class="mt-4 space-y-4">
      {% for shayari in liked_shayaris %}
        <div>
          <a class="text-lg font-display hover:underline" href="{{ url('shayari:detail', pk=shayari.pk) }}">{{ shayari.title }}</a>
          <p class="text-xs text-slate-400">{{ t('by') }} @{{ shayari.author.username }}</p>
        </div>
      {% else %}
        <p class="text-slate-400">{{ t('No likes yet.') }}</p>
      {% endfor %}
    </div>
  </div>
</section>
{% endblock %}
