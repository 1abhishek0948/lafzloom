{% extends 'base.jinja' %}

{% block title %}{{ t('Reset Password') }} | Lafzverse{% endblock %}

{% block content %}
<section class="max-w-md mx-auto">
  <p class="tag">{{ t('Reset') }}</p>
  <h1 class="text-3xl font-display">{{ t('Get a reset code.') }}</h1>
  <form method="post" class="mt-6 space-y-4 card">
    {{ csrf_input }}
    {% if form.non_field_errors() %}
      <div class="text-sm text-rose-200">{{ form.non_field_errors()|safe }}</div>
    {% endif %}
    <div>
      <label class="label">{{ t('Email') }}</label>
      {{ form.email }}
      {% if form.email.errors %}
        <div class="text-sm text-rose-200">{{ form.email.errors|safe }}</div>
      {% endif %}
    </div>
    <button class="btn-primary w-full" type="submit">{{ t('Send Code') }}</button>
  </form>
  <p class="mt-4 text-sm text-slate-400">{{ t('We will send a 6-digit code if the email exists.') }}</p>
</section>
{% endblock %}
