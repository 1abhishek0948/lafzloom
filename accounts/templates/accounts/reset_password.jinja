{% extends 'base.jinja' %}

{% block title %}{{ t('Reset Password') }} | Lafzverse{% endblock %}

{% block content %}
<section class="max-w-md mx-auto">
  <p class="tag">{{ t('Reset') }}</p>
  {% if validlink %}
    <h1 class="text-3xl font-display">{{ t('Enter a new password') }}</h1>
    <form method="post" class="mt-6 space-y-4 card">
      {{ csrf_input }}
      {% if form.non_field_errors() %}
        <div class="text-sm text-rose-200">{{ form.non_field_errors()|safe }}</div>
      {% endif %}
      <div>
        <label class="label">{{ t('New Password') }}</label>
        <div class="password-field">
          {{ form.new_password1 }}
          <button class="password-toggle" type="button" data-password-toggle data-target="id_new_password1" data-show-label="{{ t('Show password') }}" data-hide-label="{{ t('Hide password') }}" aria-label="{{ t('Show password') }}">
            <svg class="password-toggle-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span class="sr-only">{{ t('Show password') }}</span>
          </button>
        </div>
        {% if form.new_password1.errors %}
          <div class="text-sm text-rose-200">{{ form.new_password1.errors|safe }}</div>
        {% endif %}
      </div>
      <div>
        <label class="label">{{ t('Confirm Password') }}</label>
        <div class="password-field">
          {{ form.new_password2 }}
          <button class="password-toggle" type="button" data-password-toggle data-target="id_new_password2" data-show-label="{{ t('Show password') }}" data-hide-label="{{ t('Hide password') }}" aria-label="{{ t('Show password') }}">
            <svg class="password-toggle-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span class="sr-only">{{ t('Show password') }}</span>
          </button>
        </div>
        {% if form.new_password2.errors %}
          <div class="text-sm text-rose-200">{{ form.new_password2.errors|safe }}</div>
        {% endif %}
      </div>
      <button class="btn-primary w-full" type="submit">{{ t('Reset Password') }}</button>
    </form>
  {% else %}
    <h1 class="text-3xl font-display">{{ t('This reset link is invalid or expired.') }}</h1>
    <p class="mt-4 text-sm text-slate-400">
      <a class="underline" href="{{ url('accounts:forgot_password') }}">{{ t('Request a new reset link') }}</a>
    </p>
  {% endif %}
</section>
{% endblock %}
