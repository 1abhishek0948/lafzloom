{% extends 'base.jinja' %}

{% block title %}{{ t('Login') }} | Lafzloom{% endblock %}

{% block content %}
<section class="max-w-md mx-auto">
  <p class="tag">{{ t('Welcome back') }}</p>
  <h1 class="text-3xl font-display">{{ t('Login to Lafzloom') }}</h1>
  <form method="post" class="mt-6 space-y-4 card">
    {{ csrf_input }}
    {% if form.non_field_errors() %}
      <div class="text-sm text-rose-200">{{ form.non_field_errors()|safe }}</div>
    {% endif %}
    <div>
      <label class="label">{{ t('Email or Username') }}</label>
      {{ form.username }}
      {% if form.username.errors %}
        <div class="text-sm text-rose-200">{{ form.username.errors|safe }}</div>
      {% endif %}
    </div>
    <div>
      <label class="label">{{ t('Password') }}</label>
      <div class="password-field">
        {{ form.password }}
        <button class="password-toggle" type="button" data-password-toggle data-target="id_password" data-show-label="{{ t('Show password') }}" data-hide-label="{{ t('Hide password') }}" aria-label="{{ t('Show password') }}">
          <svg class="password-toggle-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <span class="sr-only">{{ t('Show password') }}</span>
        </button>
      </div>
      {% if form.password.errors %}
        <div class="text-sm text-rose-200">{{ form.password.errors|safe }}</div>
      {% endif %}
    </div>
    <button class="btn-primary w-full" type="submit">{{ t('Login') }}</button>
    <p class="text-sm text-slate-400">{{ t('New here?') }} <a class="underline" href="{{ url('accounts:register') }}">{{ t('Create an account') }}</a></p>
    <p class="text-sm text-slate-400">{{ t('Forgot password?') }} <a class="underline" href="{{ url('accounts:forgot_password') }}">{{ t('Reset via email') }}</a></p>
  </form>
</section>
{% endblock %} 
