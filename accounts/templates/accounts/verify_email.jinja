{% extends 'base.jinja' %}

{% block title %}{{ t('Verify Email') }} | Lafzverse{% endblock %}

{% block content %}
<section class="max-w-md mx-auto">
  <p class="tag">{{ t('Verify') }}</p>
  <h1 class="text-3xl font-display">{{ t('Enter the code we emailed you.') }}</h1>
  <form method="post" class="mt-6 space-y-4 card">
    {{ csrf_input }}
    {% if form.non_field_errors() %}
      <div class="text-sm text-rose-200">{{ form.non_field_errors()|safe }}</div>
    {% endif %}
    <div>
      <label class="label">{{ t('Verification Code') }}</label>
      {{ form.otp }}
      {% if form.otp.errors %}
        <div class="text-sm text-rose-200">{{ form.otp.errors|safe }}</div>
      {% endif %}
    </div>
    <button class="btn-primary w-full" type="submit">{{ t('Verify Email') }}</button>
  </form>
</section>
{% endblock %}
