DEBUG=1
SECRET_KEY=change-me-to-a-long-random-value
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=120

# Render PostgreSQL connection string (preferred in production)
DATABASE_URL=

POSTGRES_DB=lafzverse
POSTGRES_USER=lafzverse
POSTGRES_PASSWORD=lafzverse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

TRANSLATION_PROVIDER=mock
HF_API_TOKEN=
LLM_API_URL=
LLM_API_KEY=
TRANSLATION_TIMEOUT_SECONDS=20

OTP_EXPIRY_MINUTES=10
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
OTP_EMAIL_PROVIDER=smtp
DEFAULT_FROM_EMAIL=no-reply@lafzverse.com
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_TIMEOUT=15
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_SSL_CERTFILE=
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@lafzverse.com

# Production security flags (recommended for Render)
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1
SECURE_CONTENT_TYPE_NOSNIFF=1
X_FRAME_OPTIONS=DENY

# Firebase Web App config
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK (choose one)
FIREBASE_SERVICE_ACCOUNT_FILE=
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Require verified email before login (1/0)
FIREBASE_REQUIRE_EMAIL_VERIFIED=1
