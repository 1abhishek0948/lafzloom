{% extends 'base.jinja' %}

{% block title %}{{ t('Contact Us') }} | Lafzverse{% endblock %}

{% block content %}
<section class="max-w-3xl">
  <p class="tag">{{ t('Contact') }}</p>
  <h1 class="text-3xl font-display">{{ t('Contact Us') }}</h1>
  <p class="mt-4 text-slate-300">{{ t("Have a question or feedback? We'd love to hear from you.") }}</p>
  <div class="mt-6 space-y-2 text-slate-300">
    <p>{{ t('Email') }}: support@lafzverse.com</p>
    <p>{{ t('We usually respond within 1-2 business days.') }}</p>
  </div>
</section>
{% endblock %}
