{% extends 'base.jinja' %}

{% block title %}{{ t('Terms & Conditions') }} | Lafzverse{% endblock %}

{% block content %}
<section class="max-w-3xl">
  <p class="tag">{{ t('Terms') }}</p>
  <h1 class="text-3xl font-display">{{ t('Terms & Conditions') }}</h1>
  <div class="mt-4 space-y-4 text-slate-300">
    <p>{{ t('By using Lafzverse, you agree to share content you have rights to post.') }}</p>
    <p>{{ t('We may remove content that violates community guidelines or applicable laws.') }}</p>
    <p>{{ t('These terms may change over time. Continued use means acceptance of updates.') }}</p>
  </div>
</section>
{% endblock %}
