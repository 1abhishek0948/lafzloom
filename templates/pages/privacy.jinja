{% extends 'base.jinja' %}

{% block title %}{{ t('Privacy Policy') }} | Lafzloom{% endblock %}

{% block content %}
<section class="max-w-3xl">
  <p class="tag">{{ t('Privacy') }}</p>
  <h1 class="text-3xl font-display">{{ t('Privacy Policy') }}</h1>
  <p class="mt-4 text-slate-300">{{ t('We respect your privacy and only collect the information needed to run Lafzloom.') }}</p>
  <div class="mt-6 space-y-4 text-slate-300">
    <p>{{ t('We use your email for account access and verification. We do not sell your data.') }}</p>
    <p>{{ t('Cookies are used for login sessions and basic security. You can request deletion of your account and content.') }}</p>
    <p>{{ t('For questions, reach out via the Contact Us page.') }}</p>
  </div>
</section>
{% endblock %}
